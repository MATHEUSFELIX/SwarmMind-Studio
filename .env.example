# SwarmMind Studio — Environment Variables
# Copy this file to .env and fill in your keys.
# ─────────────────────────────────────────────

# Active provider on startup: openai | gemini | anthropic | ollama
VITE_LLM_PROVIDER=ollama

# ── OpenAI ────────────────────────────────────────────────────────────────────
VITE_OPENAI_API_KEY=sk-...
VITE_OPENAI_BASE_URL=https://api.openai.com/v1
VITE_OPENAI_MODEL=gpt-4o-mini

# ── Google Gemini ─────────────────────────────────────────────────────────────
VITE_GEMINI_API_KEY=AIza...
VITE_GEMINI_MODEL=gemini-2.5-flash

# ── Anthropic Claude ──────────────────────────────────────────────────────────
# Calls are proxied via Vite dev server (/__proxy/anthropic) to bypass CORS.
VITE_ANTHROPIC_API_KEY=sk-ant-...
VITE_ANTHROPIC_MODEL=claude-sonnet-4-5
VITE_ANTHROPIC_USE_PROXY=1

# ── Ollama (local or Ollama Cloud) ───────────────────────────────────────────
# Leave VITE_OLLAMA_API_KEY empty for a local Ollama instance (http://localhost:11434)
# Set it to use Ollama Cloud (https://api.ollama.com)
VITE_OLLAMA_API_KEY=
VITE_OLLAMA_BASE_URL=http://localhost:11434
VITE_OLLAMA_MODEL=gemma3:4b
